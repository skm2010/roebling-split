# These are set automatically when you connect a Vercel KV store to your project.
# For local dev without KV, leave them blank — the app falls back to in-memory state
# (which resets on server restart but works fine for testing one person at a time).

KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
